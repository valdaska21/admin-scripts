# Bitwarden Adoption Report - Configuration
# Copy this file to .env and fill in your organisation's API credentials.
#
# How to obtain credentials:
#   1. Open the Bitwarden Admin Console
#   2. Go to Settings → Organisation info
#   3. Scroll to "API key" and note your client_id and client_secret
#
# The client ID format is: organization.xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

BW_CLIENT_ID=organization.xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
BW_CLIENT_SECRET=your_client_secret_here

# Optional overrides — defaults shown below
# BW_API_URL=https://api.bitwarden.com
# BW_IDENTITY_URL=https://identity.bitwarden.com
